# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Frontend ──
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/prisma/migrations/

# ── Backend ──
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ── Virtual environments ──
.venv/

# ── Environment files ──
*.env
*.env.local
*.env.*.local
!*.env.example
!backend/.env.example
!frontend/.env.example

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Debug logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──
coverage/
*.pem
.vercel

# testing
coverage/

# misc
*.pem
.vercel
